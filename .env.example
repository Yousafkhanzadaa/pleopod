# Runtime
ENVIRONMENT=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
ADMIN_API_KEY=replace-with-a-long-random-secret

# Local database and queue, used by default for development.
DATABASE_BACKEND=sqlite
QUEUE_BACKEND=sqlite
DATABASE_URL=sqlite+aiosqlite:///./local-data/pleopod.db

# Supabase/Postgres production adapter.
# Use Supabase pooler/session mode for long-running API/worker services.
# DATABASE_BACKEND=postgres
# QUEUE_BACKEND=pgmq
# DATABASE_URL=postgresql://postgres.your-ref:password@aws-0-region.pooler.supabase.com:5432/postgres
SUPABASE_URL=

# New Supabase API key model.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace
SUPABASE_SECRET_KEY=sb_secret_replace

# Legacy keys only if your project has not migrated yet.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Preferred modern JWT verification path.
# Defaults to: {SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=

# Optional for self-hosted/offline verification. JSON string with {"keys":[...]}.
SUPABASE_JWKS_JSON=

# Legacy fallback only. Do not use for new projects unless you are mid-migration.
SUPABASE_LEGACY_JWT_SECRET=

# Local artifact storage, used by default for development.
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=local-artifacts

# Ephemeral artifact storage for scheduled publishing runs. Uses disk during
# generation, then deletes generated artifacts after successful YouTube upload.
# STORAGE_BACKEND=temporary
TEMPORARY_STORAGE_PATH=/tmp/pleopod-artifacts

# Cloudflare R2 production adapter.
# STORAGE_BACKEND=r2
R2_ACCOUNT_ID=replace
R2_ACCESS_KEY_ID=replace
R2_SECRET_ACCESS_KEY=replace
R2_BUCKET_NAME=pleopod-media
R2_PUBLIC_BASE_URL=https://media.yourdomain.com

# AI providers. Fake is safest for local pipeline wiring.
AI_PROVIDER=fake
GEMINI_API_KEY=
GEMINI_ORCHESTRATION_MODEL=gemini-2.5-flash-lite
GEMINI_RESEARCH_MODEL=gemini-2.5-flash-lite
GEMINI_SCRIPT_MODEL=gemini-2.5-flash-lite
GEMINI_VERIFICATION_MODEL=gemini-2.5-flash-lite
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_FALLBACK_MODEL=gemini-2.5-flash-preview-tts
GEMINI_IMAGE_MODEL=imagen-4.0-fast-generate-001

# Thumbnail image generation. auto uses fake images when AI_PROVIDER=fake,
# and OpenAI GPT Image otherwise.
THUMBNAIL_IMAGE_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1280x720
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_OUTPUT_FORMAT=png

# Pipeline behavior
DEFAULT_CATEGORY=Tech
REQUIRE_HUMAN_APPROVAL=false
MAX_AGENT_ATTEMPTS=3
QUEUE_VISIBILITY_TIMEOUT_SECONDS=900
QUEUE_POLL_SECONDS=5
AUDIO_EXPORT_FORMAT=mp3
TTS_GENERATION_MODE=chunked
MAX_TTS_CHUNK_CHARS=1200

# Scheduled autonomous publishing. Use pleopod-autopublish as the Railway cron command.
AUTOPUBLISH_TOPIC_MODEL=gemini-2.5-flash-lite
AUTOPUBLISH_CATEGORY=Tech
AUTOPUBLISH_AUDIENCE=curious tech listeners and software builders
AUTOPUBLISH_TARGET_DURATION_SECONDS=600
AUTOPUBLISH_LANGUAGE=en
AUTOPUBLISH_TONE=clear, smart, conversational, timely
AUTOPUBLISH_REGION=US and global English-language technology news
AUTOPUBLISH_RECENT_JOB_LIMIT=25
AUTOPUBLISH_MIN_SOURCE_URLS=3
AUTOPUBLISH_REQUIRE_TRUSTED_SOURCES=true
# Comma-separated domains that Topic Scout may use as direct factual sources.
AUTOPUBLISH_TRUSTED_SOURCE_DOMAINS=openai.com,googleblog.com,blog.google,deepmind.google,ai.google.dev,developers.googleblog.com,anthropic.com,meta.com,about.fb.com,ai.meta.com,microsoft.com,blogs.microsoft.com,azure.microsoft.com,github.blog,github.com,nvidia.com,blogs.nvidia.com,apple.com,amazon.science,aws.amazon.com,x.ai,perplexity.ai,arxiv.org,nature.com,science.org,nist.gov,nvd.nist.gov,cisa.gov,sec.gov,ftc.gov,justice.gov,europa.eu,whitehouse.gov,theverge.com,arstechnica.com,wired.com,technologyreview.com,techcrunch.com,semianalysis.com,stratechery.com,bloomberg.com,reuters.com,apnews.com,cnbc.com,wsj.com,ft.com,axios.com,theinformation.com,platformer.news,404media.co,engadget.com,cnet.com,zdnet.com,venturebeat.com,theregister.com,tomshardware.com,bleepingcomputer.com,krebsonsecurity.com,securityweek.com,darkreading.com,cyberscoop.com,nytimes.com,washingtonpost.com,bbc.com,theguardian.com,fortune.com
# Comma-separated domains that are useful for popularity signals, not authority.
AUTOPUBLISH_TREND_SOURCE_DOMAINS=news.ycombinator.com,github.com,reddit.com,producthunt.com
AUTOPUBLISH_LOCK_TTL_SECONDS=7200
AUTOPUBLISH_MAX_RUNTIME_SECONDS=7200
AUTOPUBLISH_CREATED_BY=autopublish

# Optional Remotion video generation stage.
# Requires running npm install in remotion-renderer/.
ENABLE_VIDEO_RENDERING=false
REMOTION_RENDERER_PATH=remotion-renderer
REMOTION_VIDEO_DIRECTOR_MODEL=gemini-2.5-flash-lite
REMOTION_RENDER_TIMEOUT_SECONDS=1800
REMOTION_RENDER_OUTPUT_FORMAT=mp4

# Optional YouTube upload stage.
# Requires OAuth consent for https://www.googleapis.com/auth/youtube.upload.
# The uploader itself lives in youtube-uploader/ and is invoked as an independent CLI.
ENABLE_YOUTUBE_UPLOADING=false
YOUTUBE_UPLOADER_PATH=youtube-uploader
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_DEFAULT_PRIVACY_STATUS=private
YOUTUBE_DEFAULT_CATEGORY_ID=28
YOUTUBE_UPLOAD_TIMEOUT_SECONDS=3600
YOUTUBE_NOTIFY_SUBSCRIBERS=false
YOUTUBE_SELF_DECLARED_MADE_FOR_KIDS=false


DATABASE_BACKEND=sqlite
QUEUE_BACKEND=sqlite
DATABASE_URL=sqlite+aiosqlite:///./local-data/pleopod.db
ADMIN_API_KEY=replace-with-a-long-random-secret
AI_PROVIDER=fake
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=local-artifacts
